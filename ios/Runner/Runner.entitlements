<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>get-task-allow</key>
	<true/>
	<!-- Associated Domains (Universal Links) removed for now: Apple's free
	     "Personal Team" signing does not support this capability at all —
	     even as an inert placeholder, it blocks local device builds. Re-add
	     it once enrolled in the paid Apple Developer Program (needed for
	     App Store distribution anyway). See docs/universal-links-setup.md. -->
</dict>
</plist>
